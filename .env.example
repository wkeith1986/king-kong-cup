# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored and stays on your machine.

# --- Supabase (find these in your Supabase project under Settings -> API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin login ---
# This is the password you'll type on the /admin login screen.
ADMIN_PASSWORD=kingkong2026

# Random string used to sign your admin session cookie. Any long random string is fine.
# Generate one at https://1password.com/password-generator (length 48, letters+numbers).
SESSION_SECRET=replace-me-with-a-long-random-string
